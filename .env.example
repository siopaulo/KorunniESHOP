# Site — veřejná URL (bez trailing slash)
# Lokálně: http://localhost:3001
NEXT_PUBLIC_SITE_URL=

# Supabase — https://supabase.com/dashboard/project/_/settings/api
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# Server-only — nikdy na klienta
SUPABASE_SERVICE_ROLE_KEY=

# Cloudinary — https://cloudinary.com/console
NEXT_PUBLIC_CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# Stripe — https://dashboard.stripe.com/apikeys
STRIPE_SECRET_KEY=
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=
# Webhook signing secret (Developers → Webhooks)
STRIPE_WEBHOOK_SECRET=

# Resend — https://resend.com/api-keys
RESEND_API_KEY=
RESEND_FROM_EMAIL=
ADMIN_NOTIFICATION_EMAIL=

# Sentry (volitelné) — https://sentry.io
NEXT_PUBLIC_SENTRY_DSN=
SENTRY_AUTH_TOKEN=

# GoPay — budoucí integrace
# GOPAY_CLIENT_ID=
# GOPAY_CLIENT_SECRET=

# Fakturace — budoucí integrace
# FAKTUROID_API_KEY=
